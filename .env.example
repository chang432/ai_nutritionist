# Copy to `.env` and fill in. docker-compose reads this automatically.

# Token clients use to authenticate to the OpenClaw gateway.
# Generate a long random string, e.g.:  openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-string

# Discord bot token from the Discord Developer Portal (Bot -> Reset Token).
DISCORD_BOT_TOKEN=your-discord-bot-token
