// OpenClaw configuration (JSON5 — comments allowed).
// Baked into the image and copied into the persistent volume on first boot.
{
  // --- Model provider: the local Ollama running in the `ollama` compose service ---
  models: {
    providers: {
      ollama: {
        api: "ollama",
        // Reach the sibling service by its compose name. No `/v1` suffix:
        // the native Ollama API gives reliable tool-calling.
        baseUrl: "http://ollama:11434",
        apiKey: "ollama-local",
        models: [
          {
            id: "qwen2.5:1.5b-instruct",
            name: "Qwen2.5 1.5B Instruct",
            input: ["text"],
          },
        ],
      },
    },
  },

  // --- Default agent talks to the local Qwen model ---
  agents: {
    defaults: {
      model: { primary: "ollama/qwen2.5:1.5b-instruct" },
    },
  },

  // --- WhatsApp chat channel (WhatsApp Web / QR pairing, via Baileys) ---
  channels: {
    whatsapp: {
      enabled: true,
      // No token: linking is QR-based. On first run, link the account with:
      //   docker compose exec openclaw openclaw channels login --channel whatsapp
      // Then scan the printed QR from WhatsApp on your phone (Linked Devices).
      // Auth persists under ~/.openclaw/credentials/whatsapp/ (in the volume).
      dmPolicy: "pairing",
      groupPolicy: "allowlist",
      textChunkLimit: 4000,
      sendReadReceipts: true,
      replyToMode: "first",
    },
  },
}
